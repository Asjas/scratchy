{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["TURBO_TOKEN"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "//#test:run": {
      "inputs": [
        "packages/*/src/**/*.{ts,tsx}",
        "examples/*/src/**/*.{ts,tsx}",
        "vitest.config.ts",
        "vitest.setup.ts",
        "package.json",
        "pnpm-lock.yaml",
        "tsconfig.json"
      ],
      "env": ["CI", "NODE_ENV", "DATABASE_URL", "DATABASE_SCHEMA"],
      "outputs": []
    },
    "//#test:coverage:run": {
      "inputs": [
        "packages/*/src/**/*.{ts,tsx}",
        "examples/*/src/**/*.{ts,tsx}",
        "vitest.config.ts",
        "vitest.setup.ts",
        "package.json",
        "pnpm-lock.yaml",
        "tsconfig.json"
      ],
      "env": ["CI", "NODE_ENV", "DATABASE_URL", "DATABASE_SCHEMA"],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    }
  },
  "globalDependencies": [
    "package.json",
    "pnpm-lock.yaml",
    "tsconfig.json",
    "turbo.json"
  ],
  "remoteCache": {
    "teamSlug": "codewizard",
    "enabled": true,
    "apiUrl": "https://turborepo.codewizard.training"
  }
}
