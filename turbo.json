{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "//#test:run": {
      "inputs": [
        "packages/*/src/**/*.{ts,tsx}",
        "examples/*/src/**/*.{ts,tsx}",
        "vitest.config.ts",
        "vitest.setup.ts",
        "package.json",
        "pnpm-lock.yaml",
        "tsconfig.json"
      ],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    }
  },
  "globalDependencies": ["package.json", "tsconfig.json", "turbo.json"],
  "remoteCache": {
    "teamSlug": "codewizard",
    "enabled": true,
    "apiUrl": "https://turborepo.codewizard.training"
  }
}
