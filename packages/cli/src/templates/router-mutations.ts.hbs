import { z } from "zod";
import { protectedProcedure } from "~/router.js";
import {
  create{{pascalName}},
  update{{pascalName}},
  delete{{pascalName}},
} from "~/db/mutations/{{kebabName}}s.js";

export const {{camelName}}Mutations = {
  create: protectedProcedure
    .input(
      z.object({
        {{#each columns}}
        {{this.name}}: {{{this.zodType}}}{{#unless @last}},{{/unless}}
        {{/each}}
      }),
    )
    .mutation(({ input }) => {
      return create{{pascalName}}(input);
