import { pathToFileURL } from "node:url";
import { db } from "~/db/index.js";
{{#if model}}
import { {{modelCamelName}} } from "~/db/schema/{{modelKebabName}}.js";
import { ulid } from "ulid";
{{/if}}

/**
 * Seed the database with {{pascalName}} records.
 * Run directly: node --env-file=.env src/db/seeds/{{kebabName}}.ts
 */
export async function seed{{pascalName}}() {
{{#if model}}
  await db.insert({{modelCamelName}}).values([
    {
      id: ulid(),
      // TODO: fill in seed data
    },
  ]);
{{else}}
  // TODO: add seed logic here
{{/if}}
  console.log("✓ {{pascalName}} seeded");
}

// Allow running this file directly
const scriptUrl = process.argv[1] ? pathToFileURL(process.argv[1]).href : "";
if (scriptUrl === import.meta.url) {
  await seed{{pascalName}}();
  process.exit(0);
}
