# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
TRUST_PROXY=true

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Update credentials to match docker-compose.yml.
DATABASE_URL=postgresql://scratchy:scratchy@localhost:5432/scratchy
DATABASE_SCHEMA=app

# ── Cache / Renderer ─────────────────────────────────────────────────────
# DragonflyDB (Redis-compatible) connection URL used by the renderer plugin
# for distributed render-context caching across multiple server instances.
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────────────────
# Secret key used by Better Auth to sign session tokens and cookies.
# Must be at least 32 characters.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=replace-with-a-secure-random-string-at-least-32-chars

# Application base URL used by Better Auth for trusted-origin validation.
ORIGIN=http://localhost:3000

# Better Auth base URL for callbacks and redirects.
BETTER_AUTH_URL=http://localhost:3000

# Optional pepper secret prepended to passwords before hashing.
# Adds a server-side secret so leaked DB hashes alone can't be cracked.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# PEPPER_SECRET=
