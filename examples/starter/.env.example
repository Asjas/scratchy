# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
TRUST_PROXY=true

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Update credentials to match docker-compose.yml.
DATABASE_URL=postgresql://scratchy:scratchy@localhost:5432/scratchy
DATABASE_SCHEMA=app

# ── Cache / Renderer ─────────────────────────────────────────────────────
# DragonflyDB (Redis-compatible) connection URL used by the renderer plugin
# for distributed render-context caching across multiple server instances.
REDIS_URL=redis://localhost:6379
